# Firebase (refresh token only — no email/password)
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
FIREBASE_REFRESH_TOKEN=<your refresh token>

# Postgres
DATABASE_URL=postgres://copilot:copilot@localhost:5432/copilot_preprocessor

# LLM — format: "provider:modelId"
LLM_MODEL=anthropic:claude-opus-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Preprocessor
PREPROCESS_WINDOW_DAYS=30
DRY_RUN=true        # START WITH TRUE; flip to false only after validating output

# Server
PORT=3000
