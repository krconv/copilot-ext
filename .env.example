# Firebase (refresh token only — no email/password)
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
FIREBASE_REFRESH_TOKEN=<your refresh token>

# Postgres
DATABASE_URL=postgres://copilot:copilot@localhost:5432/copilot_ext

# LLM — model name only
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Agent SDK MCP target (where the Copilot MCP server runs)
MCP_SERVER_URL=http://localhost:3000/mcp

# Preprocessor
DRY_RUN=true                 # START WITH TRUE; flip to false only after validating output
SLEEP_BETWEEN_AGENT_RUNS=    # Milliseconds to wait between processing each transaction (leave empty for no delay)

# LangSmith tracing (https://smith.langchain.com)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=copilot-ext

# Server
PORT=3000
